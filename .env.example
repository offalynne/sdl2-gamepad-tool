# macOS Code Signing & Notarization
# Copy to .env and fill in your values. Never commit .env to the repo.
#
# CODESIGN_IDENTITY: used during build (CMake) to sign the .app bundle.
#   Find yours with: security find-identity -v -p codesigning
#   Example: "Developer ID Application: Your Name (TEAMID)"
#   If unset, ad-hoc signing is used (fine for local development).
CODESIGN_IDENTITY=

# APPLE_ID: your Apple Developer account email.
#   Used by notarytool during packaging.
APPLE_ID=

# APPLE_PASSWORD: an app-specific password for notarization.
#   Generate at: https://appleid.apple.com/account/manage → App-Specific Passwords
#   You can also store it in Keychain and reference it as @keychain:NOTARIZE_PASSWORD
APPLE_PASSWORD=

# APPLE_TEAM_ID: your 10-character Apple Developer Team ID.
#   Find it at: https://developer.apple.com/account → Membership Details
APPLE_TEAM_ID=
